#simulation 1   ***AR2*** #
#hot and not humid
#warm and humid

#creates lists to append data into to be used in a graph later in the code
time_steps = []
infected_A = []
infected_B = []
step = 0

#sets grid size and cell size and margin
GRID_SIZE = 8
CELL_SIZE = 80
MARGIN = 60

#sets width and hight for the window
WIDTH = GRID_SIZE * CELL_SIZE * 2 + MARGIN
HEIGHT = GRID_SIZE * CELL_SIZE

pygame.init()  #loads all the modules, graphics, fonts, etc.
screen = pygame.display.set_mode((WIDTH, HEIGHT)) #creates the window
pygame.display.set_caption("Tree Fungus Spread Comparison") #sets the text at the top of the window

clock = pygame.time.Clock() #controles time and speed  
font = pygame.font.SysFont(None, 50) #sets font to default and font size to 50

#sets colors for later use in code  (red, green, blue) 
GREEN = (50,160,60)
BLACK = (30,30,30)
WHITE = (240,240,240)

# 2 scenarios 
scenarioA = {"temp":32, "humidity":0}   # hot and dry
scenarioB = {"temp":25, "humidity":65}  # ideal fungus conditions

healthy_tree = pygame.image.load("healthy_tree.png") # loads the tree png into game
infected_tree = pygame.image.load("infected_tree.png")

healthy_tree = pygame.transform.scale(healthy_tree, (CELL_SIZE, CELL_SIZE)) #transforms its scale into the right cell size
infected_tree = pygame.transform.scale(infected_tree, (CELL_SIZE, CELL_SIZE))

# creates two boards
gridA = [[0]*GRID_SIZE for _ in range(GRID_SIZE)]
gridB = [[0]*GRID_SIZE for _ in range(GRID_SIZE)]

# starts infection in center
gridA[2][2] = 1
gridB[2][2] = 1


#sets up a timer and sets running to true to start loop
timer = 0
running = True

while running: #lets the user close the window
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

    timer += clock.get_time() #adds time passed since last frame

    if timer > 1000:   # updates both scenarios every 1 second
        gridA = spread(gridA, scenarioA["temp"], scenarioA["humidity"])
        gridB = spread(gridB, scenarioB["temp"], scenarioB["humidity"])
        step += 1
  
        time_steps.append(step)
        infected_A.append(count_infected(gridA))
        infected_B.append(count_infected(gridB))
        #appends all results for graphs
        
        timer = 0 #starts counter again for next second
    screen.fill(WHITE) #it clears previous frame before drawing a new one

# scenario A high temp, lower humidity
    for y in range(GRID_SIZE): #goes through every square in the grid  
        for x in range(GRID_SIZE):
            if gridA[y][x] == 1: #checks if == 1 (0 for healthy tree, 1 for infected tree)
                screen.blit(infected_tree, (x*CELL_SIZE, y*CELL_SIZE))
            else: #draws the correct tree
                screen.blit(healthy_tree, (x*CELL_SIZE, y*CELL_SIZE))

# scenario B, warm and humid
    offset = GRID_SIZE*CELL_SIZE + MARGIN #calculates how far to move the second grid to the right
    for y in range(GRID_SIZE):  #goes through every square in the grid  
        for x in range(GRID_SIZE):
            if gridB[y][x] == 1:   #checks if == 1 (0 for healthy tree, 1 for infected tree)
                #draws the correct tree
                screen.blit(infected_tree, (offset + x*CELL_SIZE, y*CELL_SIZE))
            else:
                screen.blit(healthy_tree, (offset + x*CELL_SIZE, y*CELL_SIZE))

    # labels for pygame model and sets the text to black
    textA = font.render("Hot & Dry", True, BLACK)
    textB = font.render("Warm & Humid", True, BLACK)
    #sets size for the text
    screen.blit(textA, (80, HEIGHT-30))
    screen.blit(textB, (offset+60, HEIGHT-30))

    pygame.display.flip() #pushes the updated forest to screen
    clock.tick(60) #Limits the loop to 60 frames per second 

pygame.quit()

#plot results of the simulation 1

plt.plot(time_steps, infected_A, label="Hot & Dry")  #plot the graph for the hot and dry simulation
plt.plot(time_steps, infected_B, label="Warm & Humid") #plot the graph for warm and humid 

#labels the  x and y axes, and adds title 
plt.xlabel("Time Step")
