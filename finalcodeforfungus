def count_infected(grid): #function for counting infected trees
    return sum(sum(row) for row in grid) #sums up all the numbers in each line and adds them together to count the infected trees
#what a grid looks like ¬
# grid = [
#     [0, 1, 0],
#     [1, 1, 0],
#     [0, 0, 1]
# ]

# ***AR1** model
def infection_probability(temp, humidity): #calculates the probability of the fungus spreading

    temp_factor = math.exp(-((temp - 25)**2)/20) # This creates a bell curve centered at 25°C

# Temp    Spread
# 15°C    low
# 20°C    medium
# 25°C    highest
# 30°C    lower
# 35°C    very low

#how it works
# (temp - 25) distance from ideal temperature (25°C)
# (...)² makes it always positive
# /20 controls how wide the curve is
# exp(...) turns it into a smooth curve between 0 and 1

    humidity_factor = 0
    if humidity > 65:
        humidity_factor = min((humidity - 65)/35,1)
        # humidity-65 normalises the range
        # dividing by 35 creates a fraction
        # min ensures it does not exceed 1

# below 65% → little spread
# above 65% → increasing spread

    return 0.05 + 0.6*temp_factor + 0.35*humidity_factor
# 0.05 = base chance always present in forests
# 0.6 = temperature has biggest influence in this model
# 0.35 = humidity also very important

def neighbors(x,y): #function for finding nearby trees

    dirs = [(-1,0),(1,0),(0,-1),(0,1)]
#left (-1, 0)
#right (1, 0)
#up (0, -1)
#down (0, 1)
    for dx,dy in dirs: #it calculates the position of each neighbour
        nx,ny = x+dx,y+dy
        if 0 <= nx < GRID_SIZE and 0 <= ny < GRID_SIZE: #prevents going outside the grid
            yield nx,ny #returns each valid neighbour one at a time

def spread(grid,temp,humidity): #fungus spread function
    prob = infection_probability(temp,humidity) ##Calculates chance of infection based on, temp and humidity
    new = [row[:] for row in grid] #Prevents updating the grid while still reading it

    for y in range(GRID_SIZE): #loops through every tree in the forest
        for x in range(GRID_SIZE):
            if grid[y][x] == 1: #only the infected trees can spread the fungus
                for nx,ny in neighbors(x,y): #Checks all neighbouring trees using the function ( neighbors(x,y) )
                    if grid[ny][nx] == 0:  #only will infect healthy trees
                        if random.random() < prob: #infection happens randomly based on probability
                    # random.random() gives a random number between 1 and 0, if its less than prob then infection happens
                            new[ny][nx] = 1

    return new  #returns updated grid




# serial data collecting  **BR2**

ser = serial.Serial()    # Create a serial connection object (this represents the USB connection)
ser.baudrate = 115200    # Set how fast data is sent and received (must match the device's speed - 115200 is speed of a microbit)
ser.port = "COM4"        # Set the USB/COM port the device is connected to
                        

try:
    ser.open()               # Open the connection so data can be read from the device
    print("Serial connected")
    csvfile = "microbit_readings.csv"   # Name of the CSV file we will write the data to
    open(csvfile, "w").close()  # NEW: clear file so old data is not mixed with new data
    myList = []              # Create an empty list to store the data we receive
    count = 0                # Create a counter to keep track of how many readings we take

    while count < 10:        # Repeat the code below until we have read data 10 times

        data1 = ser.readline().decode().strip()
    # Read one line of data from the device
    # Convert it from computer bytes into readable text
    # Remove extra spaces and new line characters

        time.sleep(0.5)      # Pause the program for half a second
        print(data1)         # Show the received data on the screen
        myList.append(data1) # Add the received data to the list

        # Write the data to the CSV file 
        # Open the CSV file in append mode ("a") so we do not overwrite previous data
        with open(csvfile, "a", newline="") as f:
            writer = csv.writer(f)       # Create a CSV writer object
            writer.writerow([data1])     # Write the data as a single row in the CSV file
        # ---------------------------------------

        count += 1           # Increase the counter by 1

    ser.close()              # Close the connection to the device

except:
    print("Serial failed - skipping data collection") # if collecting data fails

print("Data collection complete")


